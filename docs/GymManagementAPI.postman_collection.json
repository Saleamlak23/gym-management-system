{
  "info": {
    "name": "Gym Management API",
    "description": "Complete test collection for the Gym & Fitness Club Management System. Run tests in order — Auth first to get tokens.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url",      "value": "http://localhost:5000/api" },
    { "key": "member_token",  "value": "" },
    { "key": "staff_token",   "value": "" },
    { "key": "manager_token", "value": "" }
  ],
  "item": [

    {
      "name": "00 - Health Check",
      "item": [
        {
          "name": "GET / - Server alive",
          "request": {
            "method": "GET",
            "url": "http://localhost:5000",
            "description": "Checks the server is running. No auth needed."
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('API running', () => pm.expect(pm.response.json().status).to.eql('API running'));"
            ]}
          }]
        }
      ]
    },

    {
      "name": "01 - Auth",
      "item": [
        {
          "name": "POST /auth/register - new member",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"first_name\": \"Test\",\n  \"last_name\": \"Member\",\n  \"email\": \"test.member@email.com\",\n  \"password\": \"Password@123\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 201', () => pm.response.to.have.status(201));",
              "pm.test('Has token', () => pm.expect(pm.response.json().data).to.have.property('token'));",
              "pm.test('Success true', () => pm.expect(pm.response.json().success).to.be.true);",
              "const token = pm.response.json().data?.token;",
              "if (token) pm.collectionVariables.set('member_token', token);",
              "pm.test('Token saved', () => pm.expect(pm.collectionVariables.get('member_token')).to.not.be.empty);"
            ]}
          }]
        },
        {
          "name": "POST /auth/register - duplicate email (should fail)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"first_name\": \"Test\",\n  \"last_name\": \"Member\",\n  \"email\": \"test.member@email.com\",\n  \"password\": \"Password@123\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 409 conflict', () => pm.response.to.have.status(409));",
              "pm.test('Success false', () => pm.expect(pm.response.json().success).to.be.false);"
            ]}
          }]
        },
        {
          "name": "POST /auth/register - validation error (should fail)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"first_name\": \"\",\n  \"email\": \"not-an-email\",\n  \"password\": \"short\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 422 validation', () => pm.response.to.have.status(422));",
              "pm.test('Has errors array', () => pm.expect(pm.response.json()).to.have.property('errors'));"
            ]}
          }]
        },
        {
          "name": "POST /auth/login - as member",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test.member@email.com\",\n  \"password\": \"Password@123\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Role is member', () => pm.expect(pm.response.json().data.user.role).to.eql('member'));",
              "const token = pm.response.json().data?.token;",
              "if (token) pm.collectionVariables.set('member_token', token);"
            ]}
          }]
        },
        {
          "name": "POST /auth/login - as branch manager (seeded staff)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alem.bekele@gym.com\",\n  \"password\": \"Password@123\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Role is branch_manager', () => pm.expect(pm.response.json().data.user.role).to.eql('branch_manager'));",
              "const token = pm.response.json().data?.token;",
              "if (token) pm.collectionVariables.set('manager_token', token);"
            ]}
          }]
        },
        {
          "name": "POST /auth/login - as trainer (seeded staff)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"tigabu.wolde@gym.com\",\n  \"password\": \"Password@123\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Role is trainer', () => pm.expect(pm.response.json().data.user.role).to.eql('trainer'));",
              "const token = pm.response.json().data?.token;",
              "if (token) pm.collectionVariables.set('staff_token', token);"
            ]}
          }]
        },
        {
          "name": "POST /auth/login - wrong password (should fail)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test.member@email.com\",\n  \"password\": \"WrongPassword@999\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 401', () => pm.response.to.have.status(401));",
              "pm.test('Success false', () => pm.expect(pm.response.json().success).to.be.false);"
            ]}
          }]
        },
        {
          "name": "GET /auth/me - get current user",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/auth/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{member_token}}" }]
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Has user object', () => pm.expect(pm.response.json().data).to.have.property('user'));",
              "pm.test('Email matches', () => pm.expect(pm.response.json().data.user.email).to.eql('test.member@email.com'));"
            ]}
          }]
        },
        {
          "name": "GET /auth/me - no token (should fail)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/auth/me"
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 401', () => pm.response.to.have.status(401));"
            ]}
          }]
        }
      ]
    },

