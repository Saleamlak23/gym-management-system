# Server Settings
PORT=5000
NODE_ENV=development

# Database Settings
DB_USER=postgres
DB_PASSWORD=your_actual_pgadmin_password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gym_management

# Auth Settings
JWT_SECRET=any_long_random_string_here
JWT_EXPIRE=24h

# Frontend Connection
CLIENT_URL=http://localhost:5173



bash
cat > /mnt/user-data/outputs/.env.example << 'EOF'
# =============================================================
#  GYM & FITNESS CLUB MANAGEMENT SYSTEM
#  Backend Environment Variables
#  File: backend/.env.example
#
#  HOW TO USE:
#    1. Copy this file:  cp .env.example .env
#    2. Fill in every empty value below with your local settings
#    3. Never commit the real .env file — it is git-ignored
#    4. When you add a new variable, add the name (empty value)
#       here so teammates know it exists
#
#  QUICK START:
#    DB_PASS   → the password you set when installing PostgreSQL
#    JWT_SECRET → run this to generate one:
#                 node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# =============================================================


# -------------------------------------------------------------
#  SERVER
# -------------------------------------------------------------

# Port Express listens on
# Default: 5000 — change only if another service is using it
PORT=5000

# Runtime environment
# development → verbose logs, full error stack traces in responses
# production  → minimal logs, generic error messages to clients
# test        → used by Jest — set automatically by npm test
# Allowed values: development | production | test
NODE_ENV=development


# -------------------------------------------------------------
#  DATABASE — PostgreSQL
#
#  LOCAL DEVELOPMENT:
#    Use the credentials you set when installing PostgreSQL.
#    DB_HOST is almost always localhost for local dev.
#    DB_PORT is almost always 5432 (PostgreSQL default).
#    DB_NAME must exactly match the database you created in pgAdmin.
#    DB_USER is usually postgres (the default superuser).
#    DB_PASS is the password you set during PostgreSQL installation.
#
#  PRODUCTION (Render.com):
#    Render provides a DATABASE_URL connection string.
#    Set DATABASE_URL below and leave the individual DB_* vars empty.
#    The db.js file checks for DATABASE_URL first.
# -------------------------------------------------------------

DB_HOST=localhost
DB_PORT=5432
DB_NAME=gym_management
DB_USER=postgres
DB_PASS=

# Full connection string (Render / cloud providers)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Leave empty for local development
DATABASE_URL=

# PostgreSQL connection pool settings (optional — defaults used if omitted)
# DB_POOL_MAX     — max simultaneous connections (default: 10)
# DB_POOL_IDLE    — close idle connections after N ms (default: 30000)
# DB_POOL_TIMEOUT — error if no connection available after N ms (default: 2000)
DB_POOL_MAX=10
DB_POOL_IDLE=30000
DB_POOL_TIMEOUT=2000


# -------------------------------------------------------------
#  AUTHENTICATION — JSON Web Tokens
#
#  JWT_SECRET:
#    Must be a long, random, unguessable string (minimum 32 chars).
#    Anyone who knows this value can forge valid tokens.
#    Generate a secure one:
#      node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
#
#  JWT_EXPIRES_IN:
#    How long a token stays valid after login.
#    Format: number + unit — 7d, 24h, 60m, 3600s
#    Shorter = more secure but members log out more often.
#    Recommended: 7d for development, 1d for production.
# -------------------------------------------------------------

JWT_SECRET=
JWT_EXPIRES_IN=7d


# -------------------------------------------------------------
#  CORS — Cross-Origin Resource Sharing
#
#  CLIENT_URL must exactly match the URL of the Vite frontend.
#  In development this is always http://localhost:5173 (Vite default).
#  In production replace with your deployed Vercel URL, e.g.:
#    CLIENT_URL=https://gym-management.vercel.app
#
#  A mismatch here causes the browser to block all API requests
#  with a CORS error even though the server is running fine.
# -------------------------------------------------------------

CLIENT_URL=http://localhost:5173


# -------------------------------------------------------------
#  BCRYPT
#
#  Number of salt rounds used when hashing passwords.
#  Higher = more secure but slower. 12 is the recommended default.
#  Do not change this after users have been created — existing
#  hashes will still verify correctly (bcrypt embeds the rounds),
#  but new passwords will use the updated value.
# -------------------------------------------------------------

BCRYPT_SALT_ROUNDS=12


# -------------------------------------------------------------
#  EQUIPMENT ALERT THRESHOLDS
#
#  These control which equipment items appear in the
#  GET /api/equipment/overdue endpoint.
#
#  EQUIPMENT_OVERDUE_DAYS:
#    Flag an item if its most recent maintenance_logs.service_date
#    was more than this many days ago. Default: 90.
#
#  EQUIPMENT_COST_THRESHOLD:
#    Flag an item if SUM(maintenance_logs.cost) >= this value.
#    Indicates the item may be cheaper to replace than keep repairing.
#    Default: 5000 (in your local currency / ETB).
# -------------------------------------------------------------

EQUIPMENT_OVERDUE_DAYS=90
EQUIPMENT_COST_THRESHOLD=5000


